#!/bin/bash
# One command: ./situate  (optionally ./situate <port>)
# No args -> hardcoded default attribution data (K562 deeplift .h5),
# hypothetical mode, edits written to ./edits.csv, on 0.0.0.0:8000.
cd "$(dirname "$0")"
PORT="${1:-8000}"
exec .venv/bin/python app.py --host 0.0.0.0 --port "$PORT"
